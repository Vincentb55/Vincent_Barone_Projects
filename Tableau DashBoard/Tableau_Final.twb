    <worksheet name='Teams with &gt;= 35% Avg Away Win %'>
      <table>
        <view>
          <datasources>
            <datasource caption='mlb_stats_1901_to_2025' name='federated.0ycwjiy1wt0p8v1b3rdus0j4jilx' />
          </datasources>
          <datasource-dependencies datasource='federated.0ycwjiy1wt0p8v1b3rdus0j4jilx'>
            <column datatype='integer' name='[Away Wins]' role='measure' type='quantitative' />
            <column caption='Away Wins % of Total Season Wins' datatype='real' name='[Calculation_4871428480598019]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='[Away Wins]/[Home Wins]+[Away Wins]' />
